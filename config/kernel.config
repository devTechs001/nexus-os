# NEXUS-OS Kernel Configuration
# This file contains the core kernel configuration options

#==============================================================================
# ARCHITECTURE CONFIGURATION
#==============================================================================

# Target Architecture
# Options: x86_64, arm64, riscv64
CONFIG_ARCH=x86_64

# Architecture-specific features
CONFIG_ARCH_X86_64=y
CONFIG_ARCH_ARM64=n
CONFIG_ARCH_RISCV64=n

# CPU Features
CONFIG_CPU_FEATURE_SSE=y
CONFIG_CPU_FEATURE_SSE2=y
CONFIG_CPU_FEATURE_SSE3=y
CONFIG_CPU_FEATURE_SSSE3=y
CONFIG_CPU_FEATURE_SSE4_1=y
CONFIG_CPU_FEATURE_SSE4_2=y
CONFIG_CPU_FEATURE_AVX=y
CONFIG_CPU_FEATURE_AVX2=y
CONFIG_CPU_FEATURE_AVX512=n

#==============================================================================
# PLATFORM CONFIGURATION
#==============================================================================

# Target Platform
# Options: desktop, server, mobile, iot, embedded
CONFIG_PLATFORM=desktop

# Platform-specific optimizations
CONFIG_PLATFORM_DESKTOP=y
CONFIG_PLATFORM_SERVER=n
CONFIG_PLATFORM_MOBILE=n
CONFIG_PLATFORM_IOT=n
CONFIG_PLATFORM_EMBEDDED=n

#==============================================================================
# KERNEL CORE FEATURES
#==============================================================================

# Kernel Version
CONFIG_KERNEL_VERSION="1.0.0-alpha"
CONFIG_KERNEL_CODENAME="Genesis"

# Kernel Type
# Options: monolithic, microkernel, hybrid
CONFIG_KERNEL_TYPE=hybrid

# Preemption
CONFIG_PREEMPT=y
CONFIG_PREEMPT_VOLUNTARY=n
CONFIG_PREEMPT_FULL=y

# Symmetric Multiprocessing
CONFIG_SMP=y
CONFIG_MAX_CPUS=256
CONFIG_MAX_NUMA_NODES=8

# Time Slicing (milliseconds)
CONFIG_SCHED_TIME_SLICE_MS=10

# Maximum Processes
CONFIG_MAX_PROCESSES=65536

# Maximum Threads Per Process
CONFIG_MAX_THREADS_PER_PROCESS=4096

# Maximum Open Files Per Process
CONFIG_MAX_OPEN_FILES=65536

#==============================================================================
# MEMORY MANAGEMENT
#==============================================================================

# Kernel Memory Layout
CONFIG_KERNEL_VIRTUAL_BASE=0xFFFFFFFF80000000
CONFIG_KERNEL_STACK_SIZE=65536
CONFIG_KERNEL_HEAP_SIZE=1073741824

# Page Size
CONFIG_PAGE_SIZE=4096
CONFIG_HUGEPAGE_2M=y
CONFIG_HUGEPAGE_1G=y

# Memory Allocators
CONFIG_ALLOCATOR_BUDDY=y
CONFIG_ALLOCATOR_SLAB=y
CONFIG_ALLOCATOR_SLOB=n

# Virtual Memory
CONFIG_VMM=y
CONFIG_VMM_ASLR=y
CONFIG_VMM_KSM=n

# Memory Protection
CONFIG_MEMORY_PROTECTION=y
CONFIG_DEP=y
CONFIG_STACK_PROTECTOR=y
CONFIG_STACK_CANARY=y

#==============================================================================
# VIRTUALIZATION SUPPORT
#==============================================================================

# Hypervisor
CONFIG_HYPERVISOR=y
CONFIG_HYPERVISOR_TYPE=1

# Intel VT-x
CONFIG_VMX=y
CONFIG_EPT=y
CONFIG_VPID=y

# AMD-V
CONFIG_SVM=y
CONFIG_NPT=y

# ARM Virtualization
CONFIG_ARM_VIRT_EXT=n

# Nested Virtualization
CONFIG_NESTED_VIRT=y

# VirtIO Support
CONFIG_VIRTIO=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_SCSI=y
CONFIG_VIRTIO_FS=y
CONFIG_VIRTIO_GPU=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_RNG=y

# IOMMU Support
CONFIG_IOMMU=y
CONFIG_IOMMU_INTEL=y
CONFIG_IOMMU_AMD=y
CONFIG_IOMMU_ARM=n

#==============================================================================
# DEVICE DRIVERS
#==============================================================================

# GPU Drivers
CONFIG_DRIVER_GPU=y
CONFIG_DRIVER_GPU_INTEL=y
CONFIG_DRIVER_GPU_AMD=y
CONFIG_DRIVER_GPU_NVIDIA=y
CONFIG_DRIVER_GPU_VIRTIO=y

# Network Drivers
CONFIG_DRIVER_NETWORK=y
CONFIG_DRIVER_NETWORK_INTEL=y
CONFIG_DRIVER_NETWORK_REALTEK=y
CONFIG_DRIVER_NETWORK_BROADCOM=y
CONFIG_DRIVER_NETWORK_VIRTIO=y

# Storage Drivers
CONFIG_DRIVER_STORAGE=y
CONFIG_DRIVER_STORAGE_AHCI=y
CONFIG_DRIVER_STORAGE_NVME=y
CONFIG_DRIVER_STORAGE_SD=y
CONFIG_DRIVER_STORAGE_EMMC=y
CONFIG_DRIVER_STORAGE_VIRTIO=y

# USB Drivers
CONFIG_DRIVER_USB=y
CONFIG_DRIVER_USB_XHCI=y
CONFIG_DRIVER_USB_EHCI=y
CONFIG_DRIVER_USB_OHCI=y
CONFIG_DRIVER_USB_UHCI=y

# Input Drivers
CONFIG_DRIVER_INPUT=y
CONFIG_DRIVER_INPUT_KEYBOARD=y
CONFIG_DRIVER_INPUT_MOUSE=y
CONFIG_DRIVER_INPUT_TOUCHSCREEN=y

# Audio Drivers
CONFIG_DRIVER_AUDIO=y
CONFIG_DRIVER_AUDIO_HDA=y
CONFIG_DRIVER_AUDIO_AC97=y

#==============================================================================
# FILESYSTEMS
#==============================================================================

# Virtual Filesystem
CONFIG_VFS=y

# Native Filesystem (NexFS)
CONFIG_FS_NEXFS=y
CONFIG_FS_NEXFS_JOURNALING=y
CONFIG_FS_NEXFS_ENCRYPTION=y
CONFIG_FS_NEXFS_COMPRESSION=y

# Other Filesystems
CONFIG_FS_FAT32=y
CONFIG_FS_EXT4=y
CONFIG_FS_NTFS=n
CONFIG_FS_EXFAT=y
CONFIG_FS_ISO9660=y

# Network Filesystems
CONFIG_FS_NFS=n
CONFIG_FS_SMBFS=n

# Pseudo Filesystems
CONFIG_FS_PROC=y
CONFIG_FS_SYSFS=y
CONFIG_FS_DEVFS=y
CONFIG_FS_TMPFS=y

#==============================================================================
# NETWORKING
#==============================================================================

# Network Stack
CONFIG_NETWORK=y

# Protocol Support
CONFIG_IPV4=y
CONFIG_IPV6=y
CONFIG_ICMP=y
CONFIG_ICMPV6=y

# Transport Protocols
CONFIG_TCP=y
CONFIG_UDP=y
CONFIG_SCTP=n
CONFIG_QUIC=n

# Network Features
CONFIG_SOCKET=y
CONFIG_NETFILTER=y
CONFIG_CONNECTION_TRACKING=y
CONFIG_NAT=y

# Wireless
CONFIG_WIFI=y
CONFIG_BLUETOOTH=y
CONFIG_BLUETOOTH_LE=y

# VPN Support
CONFIG_VPN=y
CONFIG_VPN_WIREGUARD=y
CONFIG_VPN_OPENVPN=n

#==============================================================================
# SECURITY
#==============================================================================

# Security Framework
CONFIG_SECURITY=y
CONFIG_SECURITY_MAC=y
CONFIG_SECURITY_CAPABILITIES=y
CONFIG_SECURITY_SELINUX=n

# Encryption
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_CHACHA20=y
CONFIG_CRYPTO_RSA=y
CONFIG_CRYPTO_ECC=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA3=y
CONFIG_CRYPTO_BLAKE3=y

# Secure Boot
CONFIG_SECURE_BOOT=y
CONFIG_VERIFIED_BOOT=y

# TPM Support
CONFIG_TPM=y
CONFIG_TPM_VERSION=2

# Integrity Measurement
CONFIG_IMA=n

# Kernel Hardening
CONFIG_HARDENING=y
CONFIG_KASAN=n
CONFIG_KMSAN=n
CONFIG_UBSAN=y
CONFIG_KCOV=n

#==============================================================================
# POWER MANAGEMENT
#==============================================================================

# Power Management
CONFIG_POWER_MANAGEMENT=y
CONFIG_ACPI=y
CONFIG_DEVICE_TREE=n

# CPU Power States
CONFIG_CPU_IDLE=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y

# System Sleep States
CONFIG_SLEEP=y
CONFIG_SLEEP_STANDBY=y
CONFIG_SLEEP_SUSPEND=y
CONFIG_SLEEP_HIBERNATE=y

#==============================================================================
# DEBUGGING
#==============================================================================

# Debug Mode
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_SYMBOLS=y

# Debug Features
CONFIG_DEBUG_SPINLOCK=n
CONFIG_DEBUG_MUTEX=n
CONFIG_DEBUG_ATOMIC_SLEEP=n
CONFIG_DEBUG_LIST=n

# Logging
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_LOG_LEVEL=4

# Tracing
CONFIG_FTRACE=n
CONFIG_KPROBES=n
CONFIG_UPROBES=n

# Testing
CONFIG_UNIT_TESTS=n
CONFIG_INTEGRATION_TESTS=n

#==============================================================================
# PERFORMANCE
#==============================================================================

# Optimization
CONFIG_OPTIMIZE_FOR_PERFORMANCE=y
CONFIG_OPTIMIZE_FOR_SIZE=n
CONFIG_LTO=n

# Profiling
CONFIG_PROFILING=n
CONFIG_PERF_EVENTS=y

#==============================================================================
# BOOT CONFIGURATION
#==============================================================================

# Bootloader
CONFIG_BOOTLOADER=grub

# Boot Protocol
CONFIG_MULTIBOOT2=y
CONFIG_EFI=y
CONFIG_EFI_STUB=y

# Console
CONFIG_CONSOLE=y
CONFIG_CONSOLE_FRAMEBUFFER=y
CONFIG_CONSOLE_SERIAL=y
CONFIG_CONSOLE_SERIAL_BAUD=115200

# Initial RAM Disk
CONFIG_INITRD=y
CONFIG_INITRD_COMPRESSION=gzip

#==============================================================================
# MODULES
#==============================================================================

# Loadable Modules
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=n
CONFIG_MODULE_SIGNATURE=y

# Module Compression
CONFIG_MODULE_COMPRESS=y
CONFIG_MODULE_COMPRESS_GZIP=y
CONFIG_MODULE_COMPRESS_XZ=n
